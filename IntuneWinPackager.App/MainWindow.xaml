<Window x:Class="IntuneWinPackager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:modelEnums="clr-namespace:IntuneWinPackager.Models.Enums;assembly=IntuneWinPackager.Models"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource Ui.AppTitle}"
        Icon="Assets/IntuneWinPackager.ico"
        Height="900"
        Width="1450"
        MinHeight="700"
        MinWidth="1020"
        WindowStartupLocation="CenterScreen"
        Foreground="{DynamicResource WindowForegroundBrush}"
        Background="{DynamicResource PageBackgroundBrush}">
    <Grid Margin="24">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource Density.Scale}"
                            ScaleY="{DynamicResource Density.Scale}" />
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                Margin="0,0,0,16"
                CornerRadius="16"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource HeaderBorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Ui.AppTitle}" Style="{StaticResource TitleTextStyle}" />
                    <TextBlock Text="{DynamicResource Ui.AppSubtitle}"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border DockPanel.Dock="Right"
                        Background="{DynamicResource StatusPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource StatusPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,8"
                        MinWidth="280">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusTitle}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{Binding StatusBrush}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Padding="12,10"
                CornerRadius="12"
                Background="{DynamicResource UpdateNoticeBackgroundBrush}"
                BorderBrush="{DynamicResource UpdateNoticeBorderBrush}"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsUpdateNotificationVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="{DynamicResource Ui.InstallUpdate}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="10,0,0,0"
                        Command="{Binding InstallUpdateCommand}" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE946;"
                               Foreground="{DynamicResource UpdateNoticeForegroundBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding UpdateNotificationText}"
                               Foreground="{DynamicResource UpdateNoticeForegroundBrush}"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource Ui.Tab.Packaging}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.7*" MinWidth="620" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="1.3*" MinWidth="420" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.PackageConfiguration.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{DynamicResource Ui.PackageConfiguration.Description}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,4,0,14"
                                               TextWrapping="Wrap" />

                                    <Border x:Name="DropZone"
                                            Margin="0,0,0,16"
                                            CornerRadius="14"
                                            Background="{DynamicResource DropZoneBackgroundBrush}"
                                            BorderBrush="{DynamicResource DropZoneBorderBrush}"
                                            BorderThickness="2"
                                            Padding="20"
                                            AllowDrop="True"
                                            DragEnter="DropZone_DragEnter"
                                            DragOver="DropZone_DragOver"
                                            DragLeave="DropZone_DragLeave"
                                            Drop="DropZone_Drop">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{DynamicResource Ui.DropZone.Title}"
                                                       FontFamily="Segoe UI Variable Display"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{DynamicResource Ui.DropZone.Subtitle}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Ui.SourceFolder}"
                                                   Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,8,8"
                                                 Text="{Binding SourceFolder, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="0" Grid.Column="2" Margin="0,0,0,8"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="{DynamicResource Ui.Browse}"
                                                Command="{Binding BrowseSourceFolderCommand}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Ui.SetupFile}"
                                                   Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,8,8"
                                                 Text="{Binding SetupFilePath, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="1" Grid.Column="2" Margin="0,0,0,8"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="{DynamicResource Ui.Browse}"
                                                Command="{Binding BrowseSetupFileCommand}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Ui.OutputFolder}"
                                                   Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="2" Grid.Column="1" Margin="8,0,8,0"
                                                 Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Row="2" Grid.Column="2"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="{DynamicResource Ui.Browse}"
                                                Command="{Binding BrowseOutputFolderCommand}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <DockPanel LastChildFill="True" Margin="0,0,0,12">
                                        <TextBlock Text="{DynamicResource Ui.Commands.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <Border DockPanel.Dock="Right"
                                                CornerRadius="10"
                                                Padding="10,4"
                                                Background="{DynamicResource PanelBackgroundBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding InstallerTypeDisplay}"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding InstallerTypeBrush}" />
                                        </Border>
                                    </DockPanel>

                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            CornerRadius="10"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding MsiMetadataSummary}"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMsiInstaller}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Ui.Commands.AutoHint}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="{DynamicResource Ui.InstallCommand}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Text="{Binding InstallCommand, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,10"
                                             MinHeight="34" />

                                    <TextBlock Text="{DynamicResource Ui.UninstallCommand}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Text="{Binding UninstallCommand, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,10"
                                             MinHeight="34" />

                                    <CheckBox Content="{DynamicResource Ui.SilentSwitchVerified}"
                                              IsChecked="{Binding SilentSwitchesVerified}"
                                              Margin="0,0,0,10">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSilentSwitchReviewVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>

                                    <TextBlock Text="{Binding SwitchVerificationStatus}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSwitchVerificationStatusVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <CheckBox Content="{DynamicResource Ui.SmartStaging}"
                                              IsChecked="{Binding UseSmartSourceStaging}"
                                              Margin="0,0,0,12" />

                                    <TextBlock Text="{DynamicResource Ui.SimpleModeHint}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,0,0,10"
                                               TextWrapping="Wrap" />

                                    <Expander Header="{DynamicResource Ui.AdvancedSettings.Title}"
                                              Margin="0,0,0,12"
                                              IsExpanded="False">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="{DynamicResource Ui.AdvancedSettings.Description}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       Margin="0,0,0,10"
                                                       TextWrapping="Wrap" />

                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="{DynamicResource Ui.SilentPreset}" Style="{StaticResource BodyTextStyle}" />
                                                <DockPanel Margin="0,6,0,0">
                                                    <ComboBox ItemsSource="{Binding ExePresets}"
                                                              SelectedItem="{Binding SelectedPreset}"
                                                              DisplayMemberPath="Name"
                                                              MinHeight="30"
                                                              Margin="0,0,8,0" />
                                                    <Button DockPanel.Dock="Right"
                                                            Width="118"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Content="{DynamicResource Ui.ApplyPreset}"
                                                            Command="{Binding ApplyPresetCommand}" />
                                                </DockPanel>
                                                <TextBlock Text="{DynamicResource Ui.SilentPresetHint}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           FontSize="11"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap" />
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExeInstaller}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                            </StackPanel>

                                            <Border Margin="0,0,0,10"
                                                    Padding="10"
                                                    CornerRadius="10"
                                                    Background="{DynamicResource PanelBackgroundBrush}"
                                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AppliedTemplateName}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold">
                                                        <Run Text="{DynamicResource Ui.CommandProfile}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding AppliedTemplateName}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding TemplateGuidance}"
                                                               Style="{StaticResource BodyTextStyle}"
                                                               Margin="0,4,0,0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <TextBlock Text="{DynamicResource Ui.IntuneInstallRules.Title}" Style="{StaticResource SectionTitleTextStyle}" Margin="0,2,0,8" />
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{DynamicResource Ui.InstallContext}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <ComboBox Grid.Row="0" Grid.Column="1"
                                                          ItemsSource="{Binding InstallContexts}"
                                                          SelectedItem="{Binding InstallContext}"
                                                          MinHeight="30"
                                                          Margin="8,0,0,8" />

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="{DynamicResource Ui.RestartBehavior}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <ComboBox Grid.Row="1" Grid.Column="1"
                                                          ItemsSource="{Binding RestartBehaviors}"
                                                          SelectedItem="{Binding RestartBehavior}"
                                                          MinHeight="30"
                                                          Margin="8,0,0,8" />

                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                           Text="{DynamicResource Ui.MaxRunTime}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <DockPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBox Text="{Binding MaxRunTimeMinutes, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="90"
                                                             VerticalContentAlignment="Center" />
                                                    <TextBlock Text="{DynamicResource Ui.Minutes}"
                                                               Style="{StaticResource BodyTextStyle}"
                                                               Margin="8,6,0,0" />
                                                </DockPanel>
                                            </Grid>

                                            <TextBlock Text="{DynamicResource Ui.IntuneRequirements.Title}" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,8" />
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{DynamicResource Ui.OsArchitecture}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <ComboBox Grid.Row="0" Grid.Column="1"
                                                          ItemsSource="{Binding RequirementArchitectures}"
                                                          SelectedItem="{Binding RequirementOperatingSystemArchitecture}"
                                                          Margin="8,0,0,8"
                                                          MinHeight="30" />

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="{DynamicResource Ui.MinimumOs}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <ComboBox Grid.Row="1" Grid.Column="1"
                                                          ItemsSource="{Binding MinimumOperatingSystemOptions}"
                                                          SelectedItem="{Binding RequirementMinimumOperatingSystem}"
                                                          Margin="8,0,0,8"
                                                          MinHeight="30" />

                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                           Text="{DynamicResource Ui.DiskMb}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="2" Grid.Column="1"
                                                         Margin="8,0,0,8"
                                                         Text="{Binding RequirementMinimumFreeDiskSpaceMb, UpdateSourceTrigger=PropertyChanged}" />

                                                <TextBlock Grid.Row="3" Grid.Column="0"
                                                           Text="{DynamicResource Ui.MemoryMb}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="3" Grid.Column="1"
                                                         Margin="8,0,0,8"
                                                         Text="{Binding RequirementMinimumMemoryMb, UpdateSourceTrigger=PropertyChanged}" />

                                                <TextBlock Grid.Row="4" Grid.Column="0"
                                                           Text="{DynamicResource Ui.CpuMhz}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="4" Grid.Column="1"
                                                         Margin="8,0,0,8"
                                                         Text="{Binding RequirementMinimumCpuSpeedMhz, UpdateSourceTrigger=PropertyChanged}" />

                                                <TextBlock Grid.Row="5" Grid.Column="0"
                                                           Text="{DynamicResource Ui.Processors}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           VerticalAlignment="Center" />
                                                <TextBox Grid.Row="5" Grid.Column="1"
                                                         Margin="8,0,0,0"
                                                         Text="{Binding RequirementMinimumLogicalProcessors, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <TextBlock Text="{DynamicResource Ui.RequirementScriptOptional}" Style="{StaticResource BodyTextStyle}" />
                                            <TextBox Text="{Binding RequirementScriptBody, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,6,0,8"
                                                     MinHeight="90"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     TextWrapping="Wrap"
                                                     FontFamily="Consolas"
                                                     FontSize="12" />
                                            <WrapPanel Margin="0,0,0,10">
                                                <CheckBox Content="{DynamicResource Ui.RequirementScriptRun32}"
                                                          IsChecked="{Binding RequirementScriptRunAs32BitOn64System}" />
                                                <CheckBox Content="{DynamicResource Ui.RequirementScriptSignature}"
                                                          IsChecked="{Binding RequirementScriptEnforceSignatureCheck}"
                                                          Margin="14,0,0,0" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Expander>

                                    <TextBlock Text="{DynamicResource Ui.IntuneDetectionRule.Title}" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,8" />
                                    <TextBlock Text="{DynamicResource Ui.DetectionRuleHint}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,0,0,8"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{DynamicResource Ui.RuleType}" Style="{StaticResource BodyTextStyle}" />
                                    <ComboBox ItemsSource="{Binding DetectionRuleTypes}"
                                              SelectedItem="{Binding DetectionRuleType}"
                                              Margin="0,6,0,10"
                                              MinHeight="30" />
                                    <Grid Margin="0,0,0,10">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMsiDetectionRule}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{DynamicResource Ui.ProductCode}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Margin="8,0,0,8"
                                                 Text="{Binding DetectionMsiProductCode, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="{DynamicResource Ui.ProductVersion}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Margin="8,0,0,0"
                                                 Text="{Binding DetectionMsiProductVersion, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFileDetectionRule}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{DynamicResource Ui.FolderPath}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Margin="8,0,0,8"
                                                 Text="{Binding DetectionFilePath, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="{DynamicResource Ui.FileOrFolder}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Margin="8,0,0,8"
                                                 Text="{Binding DetectionFileOrFolderName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="{DynamicResource Ui.Operator}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding DetectionOperators}"
                                                  SelectedItem="{Binding DetectionFileOperator}"
                                                  MinHeight="30"
                                                  Margin="8,0,0,8" />

                                        <TextBlock Grid.Row="3" Grid.Column="0"
                                                   Text="{DynamicResource Ui.Value}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="3" Grid.Column="1"
                                                 Margin="8,0,0,8"
                                                 Text="{Binding DetectionFileValue, UpdateSourceTrigger=PropertyChanged}" />

                                        <CheckBox Grid.Row="4" Grid.Column="1"
                                                  Content="{DynamicResource Ui.Check32BitPath}"
                                                  IsChecked="{Binding DetectionFileCheck32BitOn64System}"
                                                  Margin="8,0,0,0" />
                                    </Grid>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRegistryDetectionRule}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{DynamicResource Ui.Hive}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="0" Grid.Column="1"
                                                  ItemsSource="{Binding RegistryHives}"
                                                  SelectedItem="{Binding DetectionRegistryHive}"
                                                  MinHeight="30"
                                                  Margin="8,0,0,8" />

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="{DynamicResource Ui.KeyPath}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Margin="8,0,0,8"
                                                 Text="{Binding DetectionRegistryKeyPath, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="{DynamicResource Ui.ValueName}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                 Margin="8,0,0,8"
                                                 Text="{Binding DetectionRegistryValueName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="3" Grid.Column="0"
                                                   Text="{DynamicResource Ui.Operator}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="3" Grid.Column="1"
                                                  ItemsSource="{Binding DetectionOperators}"
                                                  SelectedItem="{Binding DetectionRegistryOperator}"
                                                  MinHeight="30"
                                                  Margin="8,0,0,8" />

                                        <TextBlock Grid.Row="4" Grid.Column="0"
                                                   Text="{DynamicResource Ui.Value}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   VerticalAlignment="Center" />
                                        <TextBox Grid.Row="4" Grid.Column="1"
                                                 Margin="8,0,0,8"
                                                 Text="{Binding DetectionRegistryValue, UpdateSourceTrigger=PropertyChanged}" />

                                        <CheckBox Grid.Row="5" Grid.Column="1"
                                                  Content="{DynamicResource Ui.Use32BitRegistry}"
                                                  IsChecked="{Binding DetectionRegistryCheck32BitOn64System}"
                                                  Margin="8,0,0,0" />
                                    </Grid>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsScriptDetectionRule}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="{DynamicResource Ui.DetectionScript}"
                                                   Style="{StaticResource BodyTextStyle}" />
                                        <TextBox Grid.Row="1"
                                                 Text="{Binding DetectionScriptBody, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,6,0,8"
                                                 MinHeight="120"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Consolas"
                                                 FontSize="12" />
                                        <WrapPanel Grid.Row="2">
                                            <CheckBox Content="{DynamicResource Ui.RunScript32}"
                                                      IsChecked="{Binding DetectionScriptRunAs32BitOn64System}" />
                                            <CheckBox Content="{DynamicResource Ui.EnforceSignature}"
                                                      IsChecked="{Binding DetectionScriptEnforceSignatureCheck}"
                                                      Margin="14,0,0,0" />
                                        </WrapPanel>
                                    </Grid>

                                    <WrapPanel>
                                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                                Content="{DynamicResource Ui.StartPackaging}"
                                                MinWidth="130"
                                                Command="{Binding PackageCommand}" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="{DynamicResource Ui.FixForMe}"
                                                MinWidth="120"
                                                Margin="10,0,0,0"
                                                Command="{Binding QuickFixCommand}" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="{DynamicResource Ui.Reset}"
                                                MinWidth="110"
                                                Margin="10,0,0,0"
                                                Command="{Binding ResetCommand}" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Content="{DynamicResource Ui.OpenOutput}"
                                                MinWidth="130"
                                                Margin="10,0,0,0"
                                                Command="{Binding OpenOutputFolderCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <GridSplitter Grid.Column="1"
                                      Width="8"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="{DynamicResource PanelBorderBrush}"
                                      ShowsPreview="True"
                                      ResizeDirection="Columns"
                                      ResizeBehavior="PreviousAndNext"
                                      Margin="0,4" />

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.Result.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{Binding StatusMessage}"
                                               Style="{StaticResource BodyTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,8" />
                                    <TextBlock Text="{DynamicResource Ui.Result.StartToSeeProgress}"
                                               Margin="0,0,0,8">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPackagingRun}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Border CornerRadius="10"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPackagingRun}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PackagingProgressLabel}"
                                                       FontFamily="Segoe UI Variable Text"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding PackagingProgressDetail}"
                                                       Style="{StaticResource BodyTextStyle}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,2,0,8" />
                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding PackagingProgressPercentage}"
                                                         IsIndeterminate="{Binding IsPackagingProgressIndeterminate}"
                                                         Height="12" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{DynamicResource Ui.Result.OutputPackage}" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding ResultOutputPath}" IsReadOnly="True" />

                                    <TextBlock Text="{DynamicResource Ui.Result.Metadata}" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding ResultMetadataPath}" IsReadOnly="True" />

                                    <TextBlock Text="{DynamicResource Ui.Result.Checklist}" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding ResultChecklistPath}" IsReadOnly="True" />

                                    <TextBlock Text="{DynamicResource Ui.Result.PortalPreview}" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding IntunePortalChecklist}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Height="220" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <Expander Header="{DynamicResource Ui.Logs.Title}"
                                              IsExpanded="False">
                                        <Border Margin="0,8,0,0"
                                                CornerRadius="10"
                                                Background="{DynamicResource LogBackgroundBrush}"
                                                BorderBrush="{DynamicResource LogBorderBrush}"
                                                BorderThickness="1"
                                                Padding="10">
                                             <ListBox ItemsSource="{Binding Logs}"
                                                       BorderThickness="0"
                                                       Background="Transparent"
                                                       Foreground="{DynamicResource LogForegroundBrush}"
                                                       FontFamily="Consolas"
                                                       FontSize="{DynamicResource Density.LogFontSize}"
                                                       ScrollViewer.CanContentScroll="True"
                                                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                       VirtualizingPanel.IsVirtualizing="True"
                                                       VirtualizingPanel.VirtualizationMode="Recycling"
                                                       HorizontalContentAlignment="Stretch"
                                                       Height="{DynamicResource Density.LogHeight}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   TextWrapping="NoWrap"
                                                                   Foreground="{DynamicResource LogForegroundBrush}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="{DynamicResource Density.LogFontSize}" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource Ui.Tab.ToolsChecks}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.GuidedStart.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{Binding NextStepHint}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,6,0,10"
                                               TextWrapping="Wrap" />

                                    <Border CornerRadius="10"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,10">
                                        <TextBlock Text="{Binding ReadinessSummary}"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <WrapPanel>
                                        <Button Content="{DynamicResource Ui.GuidedStart.FixCommon}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding QuickFixCommand}" />
                                        <Button Content="{DynamicResource Ui.GuidedStart.RunPreflight}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding RunPreflightCommand}" />
                                        <Button Content="{DynamicResource Ui.GuidedStart.InstallTool}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding InstallToolCommand}" />
                                        <Button Content="{DynamicResource Ui.GuidedStart.StartPackaging}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding PackageCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="{DynamicResource Ui.Preflight.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                        <Button DockPanel.Dock="Right"
                                                Content="{DynamicResource Ui.Preflight.Run}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding RunPreflightCommand}" />
                                    </DockPanel>

                                    <TextBlock Text="{Binding PreflightSummary}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,2,0,10"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="{DynamicResource Ui.Preflight.Empty}"
                                               Margin="0,0,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPreflightRun}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl ItemsSource="{Binding PreflightChecks}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPreflightRun}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,3,0,0" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
                                                            <Setter Property="FontSize" Value="12" />
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Passed}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="{x:Static modelEnums:PreflightSeverity.Warning}">
                                                                    <Setter Property="Foreground" Value="#FFBD8A19" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="- " />
                                                    <Run Text="{Binding Title}" FontWeight="SemiBold" />
                                                    <Run Text=": " />
                                                    <Run Text="{Binding Message}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.Validation.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{DynamicResource Ui.Validation.Description}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,4,0,10"
                                               TextWrapping="Wrap" />

                                    <ItemsControl ItemsSource="{Binding ValidationErrors}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasValidationErrors}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat=- {0}}"
                                                           Foreground="{DynamicResource ErrorBrush}"
                                                           FontFamily="Segoe UI Variable Text"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"
                                                           TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="{DynamicResource Ui.Validation.Ready}"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="12"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasValidationErrors}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.Verification.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBox Text="{DynamicResource Ui.Verification.Body}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Height="220"
                                             Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource Ui.Tab.UpdatesChanges}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.AppUpdates.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{Binding CurrentVersionDisplay}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding LatestVersionDisplay}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,2,0,10" />

                                    <CheckBox Content="{DynamicResource Ui.SilentUpdateMode}"
                                              IsChecked="{Binding EnableSilentAppUpdates}"
                                              Margin="0,0,0,8" />
                                    <TextBlock Text="{DynamicResource Ui.SilentUpdateHint}"
                                               Style="{StaticResource BodyTextStyle}"
                                               FontSize="11"
                                               Margin="0,0,0,10" />

                                    <WrapPanel Margin="0,0,0,10">
                                        <Button Content="{DynamicResource Ui.CheckForUpdates}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding CheckForUpdatesCommand}" />
                                        <Button Content="{DynamicResource Ui.InstallUpdate}"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding InstallUpdateCommand}" />
                                    </WrapPanel>

                                    <Border CornerRadius="10"
                                            Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <TextBlock Text="{Binding UpdateStatus}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <TextBlock Text="{DynamicResource Ui.Changelog}"
                                               Style="{StaticResource BodyTextStyle}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6" />
                                    <TextBox Text="{Binding UpdateChangelog}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Height="220" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.RecentPackages.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{DynamicResource Ui.RecentPackages.Description}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,4,0,10" />

                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">
                                        <ItemsControl ItemsSource="{Binding RecentHistory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="10"
                                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                                            BorderThickness="1"
                                                            Background="{DynamicResource PanelBackgroundBrush}"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding SetupFilePath}"
                                                                       FontFamily="Segoe UI Variable Text"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding TimestampUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                                       Style="{StaticResource BodyTextStyle}"
                                                                       Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding Message}"
                                                                       Style="{StaticResource BodyTextStyle}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource Ui.Tab.Settings}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.Preferences.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{DynamicResource Ui.Preferences.Description}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,4,0,12"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="{DynamicResource Ui.Language}" Style="{StaticResource BodyTextStyle}" />
                                    <ComboBox ItemsSource="{Binding LanguageOptions}"
                                              SelectedItem="{Binding SelectedLanguage}"
                                              Margin="0,6,0,10"
                                              MinHeight="30" />

                                    <TextBlock Text="{DynamicResource Ui.Theme}" Style="{StaticResource BodyTextStyle}" />
                                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                                              SelectedItem="{Binding SelectedTheme}"
                                              Margin="0,6,0,12"
                                              MinHeight="30" />

                                    <TextBlock Text="{DynamicResource Ui.Density}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Text="{Binding SelectedDensity}"
                                             Margin="0,6,0,12"
                                             MinHeight="30"
                                             IsReadOnly="True" />

                                    <CheckBox Content="{DynamicResource Ui.LowImpactMode}"
                                              IsChecked="{Binding UseLowImpactMode}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Ui.SettingsProfiles.Title}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{DynamicResource Ui.SettingsProfiles.Description}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,4,0,12"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="{DynamicResource Ui.ToolPath}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Text="{Binding IntuneWinAppUtilPath, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,8" />

                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Content="{DynamicResource Ui.BrowseTool}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding BrowseToolPathCommand}" />
                                        <Button Content="{DynamicResource Ui.AutoLocate}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding AutoLocateToolCommand}" />
                                        <Button Content="{DynamicResource Ui.InstallTool}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding InstallToolCommand}" />
                                    </WrapPanel>

                                    <TextBlock Text="{DynamicResource Ui.ProfileName}" Style="{StaticResource BodyTextStyle}" />
                                    <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,6,0,8" />

                                    <TextBlock Text="{DynamicResource Ui.SavedProfiles}" Style="{StaticResource BodyTextStyle}" />
                                    <ComboBox ItemsSource="{Binding AvailableProfiles}"
                                              SelectedItem="{Binding SelectedProfileName}"
                                              Margin="0,6,0,8"
                                              MinHeight="30" />

                                    <WrapPanel>
                                        <Button Content="{DynamicResource Ui.SaveProfile}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding SaveProfileCommand}" />
                                        <Button Content="{DynamicResource Ui.LoadProfile}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding LoadProfileCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

