<Window x:Class="IntuneWinPackager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:modelEnums="clr-namespace:IntuneWinPackager.Models.Enums;assembly=IntuneWinPackager.Models"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Intune Win Packager"
        Icon="Assets/IntuneWinPackager.ico"
        Height="900"
        Width="1450"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                Margin="0,0,0,16"
                CornerRadius="16"
                Background="#F2FFFFFF"
                BorderBrush="#FFD6E1F0"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel>
                    <TextBlock Text="Intune Win Packager" Style="{StaticResource TitleTextStyle}" />
                    <TextBlock Text="Convert MSI, EXE, APPX/MSIX, and script-based installers into .intunewin packages using Microsoft's official packaging utility."
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Border DockPanel.Dock="Right"
                        Background="#FFEAF1FB"
                        BorderBrush="#FFD0DEEF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,8"
                        MinWidth="230">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusTitle}"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{Binding StatusBrush}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Package Configuration" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Drag-and-drop a setup package or pick folders and file paths manually."
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,4,0,14" />

                            <Border x:Name="DropZone"
                                    Margin="0,0,0,16"
                                    CornerRadius="14"
                                    Background="#FFF5F9FF"
                                    BorderBrush="#FFB8CAE6"
                                    BorderThickness="2"
                                    Padding="20"
                                    AllowDrop="True"
                                    DragEnter="DropZone_DragEnter"
                                    DragOver="DropZone_DragOver"
                                    DragLeave="DropZone_DragLeave"
                                    Drop="DropZone_Drop">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Drop Setup Package Here"
                                               FontFamily="Segoe UI Variable Display"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#FF20406B"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Supported: .msi, .exe, .appx/.msix (.bundle), .ps1, .cmd, .bat, .vbs"
                                               Style="{StaticResource BodyTextStyle}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Source Folder"
                                           Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,8,8"
                                         Text="{Binding SourceFolder, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="0" Grid.Column="2" Margin="0,0,0,8"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Browse"
                                        Command="{Binding BrowseSourceFolderCommand}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Setup File"
                                           Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,8,8"
                                         Text="{Binding SetupFilePath, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="1" Grid.Column="2" Margin="0,0,0,8"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Browse"
                                        Command="{Binding BrowseSetupFileCommand}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Output Folder"
                                           Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="8,0,8,0"
                                         Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="2" Grid.Column="2"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Browse"
                                        Command="{Binding BrowseOutputFolderCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <DockPanel LastChildFill="True" Margin="0,0,0,12">
                                <TextBlock Text="Install Commands" Style="{StaticResource SectionTitleTextStyle}" />
                                <Border DockPanel.Dock="Right"
                                        CornerRadius="10"
                                        Padding="10,4"
                                        Background="#FFEEF4FE"
                                        BorderBrush="#FFD2DEF1"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding InstallerTypeDisplay}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding InstallerTypeBrush}" />
                                </Border>
                            </DockPanel>

                            <Border Margin="0,0,0,10"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="#FFF8FBFF"
                                    BorderBrush="#FFD8E5F4"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding MsiMetadataSummary}"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMsiInstaller}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="Silent Preset (EXE)" Style="{StaticResource BodyTextStyle}" />
                                <DockPanel Margin="0,6,0,0">
                                    <ComboBox ItemsSource="{Binding ExePresets}"
                                              SelectedItem="{Binding SelectedPreset}"
                                              DisplayMemberPath="Name"
                                              MinHeight="36"
                                              Margin="0,0,8,0" />
                                    <Button DockPanel.Dock="Right"
                                            Width="118"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="Apply Preset"
                                            Command="{Binding ApplyPresetCommand}" />
                                </DockPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExeInstaller}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                            </StackPanel>

                            <Border Margin="0,0,0,10"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="#FFF8FBFF"
                                    BorderBrush="#FFD8E5F4"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AppliedTemplateName}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding AppliedTemplateName, StringFormat=Command profile: {0}}"
                                               Style="{StaticResource BodyTextStyle}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding TemplateGuidance}"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Install Command" Style="{StaticResource BodyTextStyle}" />
                            <TextBox Text="{Binding InstallCommand, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,10"
                                     MinHeight="40" />

                            <TextBlock Text="Uninstall Command" Style="{StaticResource BodyTextStyle}" />
                            <TextBox Text="{Binding UninstallCommand, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,10"
                                     MinHeight="40" />

                            <CheckBox Content="Silent switches verified for this EXE build"
                                      IsChecked="{Binding SilentSwitchesVerified}"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="12"
                                      Foreground="#FF425170"
                                      Margin="0,0,0,10">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSilentSwitchReviewVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>

                            <CheckBox Content="Use smart source staging (prevents recursive output packaging)"
                                      IsChecked="{Binding UseSmartSourceStaging}"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="12"
                                      Foreground="#FF425170"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="Intune Install Rules" Style="{StaticResource SectionTitleTextStyle}" Margin="0,2,0,8" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Install Context"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding InstallContexts}"
                                          SelectedItem="{Binding InstallContext}"
                                          MinHeight="34"
                                          Margin="8,0,0,8" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Restart Behavior"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding RestartBehaviors}"
                                          SelectedItem="{Binding RestartBehavior}"
                                          MinHeight="34"
                                          Margin="8,0,0,8" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Max Run Time"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <DockPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBox Text="{Binding MaxRunTimeMinutes, UpdateSourceTrigger=PropertyChanged}"
                                             Width="90"
                                             VerticalContentAlignment="Center" />
                                    <TextBlock Text="minutes"
                                               Style="{StaticResource BodyTextStyle}"
                                               Margin="8,6,0,0" />
                                </DockPanel>
                            </Grid>

                            <TextBlock Text="Intune Requirements" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="OS Architecture"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding RequirementArchitectures}"
                                          SelectedItem="{Binding RequirementOperatingSystemArchitecture}"
                                          Margin="8,0,0,8"
                                          MinHeight="34" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Minimum OS"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          ItemsSource="{Binding MinimumOperatingSystemOptions}"
                                          SelectedItem="{Binding RequirementMinimumOperatingSystem}"
                                          Margin="8,0,0,8"
                                          MinHeight="34" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Disk (MB)"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding RequirementMinimumFreeDiskSpaceMb, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="Memory (MB)"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="3" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding RequirementMinimumMemoryMb, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="4" Grid.Column="0"
                                           Text="CPU (MHz)"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="4" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding RequirementMinimumCpuSpeedMhz, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="5" Grid.Column="0"
                                           Text="Processors"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="5" Grid.Column="1"
                                         Margin="8,0,0,0"
                                         Text="{Binding RequirementMinimumLogicalProcessors, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <TextBlock Text="Requirement Script (optional)" Style="{StaticResource BodyTextStyle}" />
                            <TextBox Text="{Binding RequirementScriptBody, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,8"
                                     MinHeight="90"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     FontSize="12" />
                            <WrapPanel Margin="0,0,0,10">
                                <CheckBox Content="Run requirement script as 32-bit process on 64-bit clients"
                                          IsChecked="{Binding RequirementScriptRunAs32BitOn64System}"
                                          FontFamily="Segoe UI Variable Text"
                                          FontSize="12"
                                          Foreground="#FF425170" />
                                <CheckBox Content="Enforce requirement script signature check"
                                          IsChecked="{Binding RequirementScriptEnforceSignatureCheck}"
                                          FontFamily="Segoe UI Variable Text"
                                          FontSize="12"
                                          Foreground="#FF425170"
                                          Margin="14,0,0,0" />
                            </WrapPanel>

                            <TextBlock Text="Intune Detection Rule" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,8" />
                            <TextBlock Text="Rule Type" Style="{StaticResource BodyTextStyle}" />
                            <ComboBox ItemsSource="{Binding DetectionRuleTypes}"
                                      SelectedItem="{Binding DetectionRuleType}"
                                      Margin="0,6,0,10"
                                      MinHeight="36" />

                            <Grid Margin="0,0,0,10">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMsiDetectionRule}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Product Code"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding DetectionMsiProductCode, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Product Version"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Margin="8,0,0,0"
                                         Text="{Binding DetectionMsiProductVersion, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFileDetectionRule}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Folder Path"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding DetectionFilePath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="File/Folder"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding DetectionFileOrFolderName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Operator"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding DetectionOperators}"
                                          SelectedItem="{Binding DetectionFileOperator}"
                                          MinHeight="34"
                                          Margin="8,0,0,8" />

                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="Value"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="3" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding DetectionFileValue, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Grid.Row="4" Grid.Column="1"
                                          Content="Check 32-bit path on 64-bit clients"
                                          IsChecked="{Binding DetectionFileCheck32BitOn64System}"
                                          FontFamily="Segoe UI Variable Text"
                                          FontSize="12"
                                          Foreground="#FF425170"
                                          Margin="8,0,0,0" />
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRegistryDetectionRule}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Hive"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding RegistryHives}"
                                          SelectedItem="{Binding DetectionRegistryHive}"
                                          MinHeight="34"
                                          Margin="8,0,0,8" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="Key Path"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding DetectionRegistryKeyPath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="Value Name"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding DetectionRegistryValueName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Text="Operator"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          ItemsSource="{Binding DetectionOperators}"
                                          SelectedItem="{Binding DetectionRegistryOperator}"
                                          MinHeight="34"
                                          Margin="8,0,0,8" />

                                <TextBlock Grid.Row="4" Grid.Column="0"
                                           Text="Value"
                                           Style="{StaticResource BodyTextStyle}"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="4" Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding DetectionRegistryValue, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Grid.Row="5" Grid.Column="1"
                                          Content="Use 32-bit registry on 64-bit clients"
                                          IsChecked="{Binding DetectionRegistryCheck32BitOn64System}"
                                          FontFamily="Segoe UI Variable Text"
                                          FontSize="12"
                                          Foreground="#FF425170"
                                          Margin="8,0,0,0" />
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScriptDetectionRule}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Detection Script"
                                           Style="{StaticResource BodyTextStyle}" />
                                <TextBox Grid.Row="1"
                                         Text="{Binding DetectionScriptBody, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,6,0,8"
                                         MinHeight="120"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="12" />
                                <WrapPanel Grid.Row="2">
                                    <CheckBox Content="Run script as 32-bit process on 64-bit clients"
                                              IsChecked="{Binding DetectionScriptRunAs32BitOn64System}"
                                              FontFamily="Segoe UI Variable Text"
                                              FontSize="12"
                                              Foreground="#FF425170" />
                                    <CheckBox Content="Enforce signature check"
                                              IsChecked="{Binding DetectionScriptEnforceSignatureCheck}"
                                              FontFamily="Segoe UI Variable Text"
                                              FontSize="12"
                                              Foreground="#FF425170"
                                              Margin="14,0,0,0" />
                                </WrapPanel>
                            </Grid>

                            <WrapPanel>
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Content="Start Packaging"
                                        MinWidth="130"
                                        Command="{Binding PackageCommand}" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Fix For Me"
                                        MinWidth="110"
                                        Margin="10,0,0,0"
                                        Command="{Binding QuickFixCommand}" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Reset"
                                        MinWidth="110"
                                        Margin="10,0,0,0"
                                        Command="{Binding ResetCommand}" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Open Output"
                                        MinWidth="130"
                                        Margin="10,0,0,0"
                                        Command="{Binding OpenOutputFolderCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="Packaging Logs" Style="{StaticResource SectionTitleTextStyle}" />
                            </DockPanel>

                            <Border CornerRadius="10"
                                    Background="#FF111927"
                                    BorderBrush="#FF0D1521"
                                    BorderThickness="1"
                                    Padding="10">
                                <ListBox ItemsSource="{Binding Logs}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#FFEAF1FE"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         Height="220" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Guided Start" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding NextStepHint}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,6,0,10"
                                       TextWrapping="Wrap" />

                            <Border CornerRadius="10"
                                    Background="#FFF8FBFF"
                                    BorderBrush="#FFD6E1F0"
                                    BorderThickness="1"
                                    Padding="10"
                                    Margin="0,0,0,10">
                                <TextBlock Text="{Binding ReadinessSummary}"
                                           FontFamily="Segoe UI Variable Text"
                                           FontSize="12"
                                           Foreground="#FF425170"
                                           TextWrapping="Wrap" />
                            </Border>

                            <WrapPanel>
                                <Button Content="Fix Common Issues"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding QuickFixCommand}" />
                                <Button Content="Run Preflight"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        Command="{Binding RunPreflightCommand}" />
                                <Button Content="Install Tool"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        Command="{Binding InstallToolCommand}" />
                                <Button Content="Start Packaging"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        Command="{Binding PackageCommand}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Settings &amp; Profiles" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Configure IntuneWinAppUtil.exe, auto-locate it, or install it in one click."
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,4,0,12" />

                            <TextBlock Text="IntuneWinAppUtil Path" Style="{StaticResource BodyTextStyle}" />
                            <TextBox Text="{Binding IntuneWinAppUtilPath, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,8" />

                            <WrapPanel Margin="0,0,0,12">
                                <Button Content="Browse Tool"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding BrowseToolPathCommand}" />
                                <Button Content="Auto Locate"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        Command="{Binding AutoLocateToolCommand}" />
                                <Button Content="Install Tool"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        Command="{Binding InstallToolCommand}" />
                            </WrapPanel>

                            <CheckBox Content="Low Impact Packaging Mode (less CPU, slower)"
                                      IsChecked="{Binding UseLowImpactMode}"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="12"
                                      Foreground="#FF425170"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="Profile Name" Style="{StaticResource BodyTextStyle}" />
                            <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,8" />

                            <TextBlock Text="Saved Profiles" Style="{StaticResource BodyTextStyle}" />
                            <ComboBox ItemsSource="{Binding AvailableProfiles}"
                                      SelectedItem="{Binding SelectedProfileName}"
                                      Margin="0,6,0,8"
                                      MinHeight="36" />

                            <WrapPanel>
                                <Button Content="Save Profile"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding SaveProfileCommand}" />
                                <Button Content="Load Profile"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        Command="{Binding LoadProfileCommand}" />
                            </WrapPanel>

                            <Separator Margin="0,14,0,12" />

                            <TextBlock Text="App Updates" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding CurrentVersion, StringFormat=Current version: {0}}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding LatestVersion, StringFormat=Latest version: {0}}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,2,0,10" />

                            <CheckBox Content="Silent update install mode (policy)"
                                      IsChecked="{Binding EnableSilentAppUpdates}"
                                      FontFamily="Segoe UI Variable Text"
                                      FontSize="12"
                                      Foreground="#FF425170"
                                      Margin="0,0,0,8" />
                            <TextBlock Text="Uses installer silent flags for managed/internal environments."
                                       Style="{StaticResource BodyTextStyle}"
                                       FontSize="11"
                                       Margin="0,0,0,10" />

                            <WrapPanel Margin="0,0,0,10">
                                <Button Content="Check for Updates"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding CheckForUpdatesCommand}" />
                                <Button Content="Install Update"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        Command="{Binding InstallUpdateCommand}" />
                            </WrapPanel>

                            <Border CornerRadius="10"
                                    Background="#FFF8FBFF"
                                    BorderBrush="#FFD5E0EF"
                                    BorderThickness="1"
                                    Padding="10"
                                    Margin="0,0,0,8">
                                <TextBlock Text="{Binding UpdateStatus}"
                                           Style="{StaticResource BodyTextStyle}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Text="Changelog"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding UpdateChangelog}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="120"
                                     Background="#FFF8FAFD"
                                     BorderBrush="#FFD5E0EF" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="Preflight Checks" Style="{StaticResource SectionTitleTextStyle}" />
                                <Button DockPanel.Dock="Right"
                                        Content="Run Preflight"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding RunPreflightCommand}" />
                            </DockPanel>

                            <TextBlock Text="{Binding PreflightSummary}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,2,0,10"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Run preflight to inspect tool health, access, and packaging readiness."
                                       Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPreflightRun}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ItemsControl ItemsSource="{Binding PreflightChecks}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPreflightRun}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,3,0,0" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
                                                    <Setter Property="FontSize" Value="12" />
                                                    <Setter Property="Foreground" Value="#FFB02A37" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Passed}" Value="True">
                                                            <Setter Property="Foreground" Value="#FF0F7A57" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static modelEnums:PreflightSeverity.Warning}">
                                                            <Setter Property="Foreground" Value="#FF9D6A00" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="• " />
                                            <Run Text="{Binding Title}" FontWeight="SemiBold" />
                                            <Run Text=": " />
                                            <Run Text="{Binding Message}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Validation" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Required fields are validated instantly before packaging starts."
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,4,0,10" />

                            <ItemsControl ItemsSource="{Binding ValidationErrors}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasValidationErrors}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat=• {0}}"
                                                   Foreground="#FFB02A37"
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="12"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="All required fields are valid. Ready to package."
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="12"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasValidationErrors}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Result" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,8" />
                            <TextBlock Text="Start packaging to show live progress."
                                       Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPackagingRun}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border CornerRadius="10"
                                    Background="#FFF8FBFF"
                                    BorderBrush="#FFD5E0EF"
                                    BorderThickness="1"
                                    Padding="10"
                                    Margin="0,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPackagingRun}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding PackagingProgressLabel}"
                                               FontFamily="Segoe UI Variable Text"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#FF27426B" />
                                    <TextBlock Text="{Binding PackagingProgressDetail}"
                                               Style="{StaticResource BodyTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,8" />
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding PackagingProgressPercentage}"
                                                 IsIndeterminate="{Binding IsPackagingProgressIndeterminate}"
                                                 Height="12" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Output Package" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                            <TextBox Text="{Binding ResultOutputPath}"
                                     IsReadOnly="True"
                                     Background="#FFF8FAFD"
                                     BorderBrush="#FFD5E0EF" />

                            <TextBlock Text="Intune Metadata" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                            <TextBox Text="{Binding ResultMetadataPath}"
                                     IsReadOnly="True"
                                     Background="#FFF8FAFD"
                                     BorderBrush="#FFD5E0EF" />

                            <TextBlock Text="Intune Checklist" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                            <TextBox Text="{Binding ResultChecklistPath}"
                                     IsReadOnly="True"
                                     Background="#FFF8FAFD"
                                     BorderBrush="#FFD5E0EF" />

                            <TextBlock Text="Portal Steps Preview" Style="{StaticResource BodyTextStyle}" Margin="0,10,0,4" />
                            <TextBox Text="{Binding IntunePortalChecklist}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="220"
                                     Background="#FFF8FAFD"
                                     BorderBrush="#FFD5E0EF" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Recent Packages" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Most recent local packaging runs."
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,4,0,10" />

                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                <ItemsControl ItemsSource="{Binding RecentHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10"
                                                    BorderBrush="#FFD6E1F0"
                                                    BorderThickness="1"
                                                    Background="#FFF8FBFF"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding SetupFilePath}"
                                                               FontFamily="Segoe UI Variable Text"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding TimestampUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss} UTC'}"
                                                               Style="{StaticResource BodyTextStyle}"
                                                               Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding Message}"
                                                               Style="{StaticResource BodyTextStyle}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>

